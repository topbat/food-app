<?xml version="1.0" encoding="UTF-8"?>
<!-- 厨房引擎服务日志配置：控制台 + logs/kitchen-service.log 按天滚动，保留7天 -->
<configuration>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n"/>

    <!-- 控制台输出 -->
    <!-- 控制台编码默认 UTF-8（请配合 chcp 65001 使用）；GBK 控制台可用 -DCONSOLE_LOG_CHARSET=GBK 覆盖 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>${CONSOLE_LOG_CHARSET:-UTF-8}</charset>
        </encoder>
    </appender>

    <!-- 滚动文件输出：按天滚动，保留7天 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/kitchen-service.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/kitchen-service.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
